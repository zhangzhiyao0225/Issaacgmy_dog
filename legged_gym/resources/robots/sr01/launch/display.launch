<launch>
  <arg
    name="model" />
  <param
    name="robot_description"
    textfile="$(find QuadrupedRobot（2026） V1.2-URDF-20260508-V3)/urdf/QuadrupedRobot（2026） V1.2-URDF-20260508-V3.urdf" />
  <node
    name="joint_state_publisher_gui"
    pkg="joint_state_publisher_gui"
    type="joint_state_publisher_gui" />
  <node
    name="robot_state_publisher"
    pkg="robot_state_publisher"
    type="robot_state_publisher" />
  <node
    name="rviz"
    pkg="rviz"
    type="rviz"
    args="-d $(find QuadrupedRobot（2026） V1.2-URDF-20260508-V3)/urdf.rviz" />
</launch>